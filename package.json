{
  "name": "@rockhopper-co/mcp-server",
  "version": "0.2.0",
  "description": "Rockhopper MCP server — expose file metadata, versions, reviews, and comments to AI tools",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "rockhopper-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "release:patch": "npm version patch -m 'release: v%s' && git push && git push --tags",
    "release:minor": "npm version minor -m 'release: v%s' && git push && git push --tags",
    "release:major": "npm version major -m 'release: v%s' && git push && git push --tags"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "rockhopper",
    "excel",
    "file-management",
    "ai-tools",
    "cursor",
    "claude"
  ],
  "author": "Rockhopper Technologies",
  "license": "MIT",
  "homepage": "https://rockhopper.co",
  "repository": {
    "type": "git",
    "url": "https://github.com/rockhopper-co/rockhopper-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/rockhopper-co/rockhopper-mcp/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
