{
  "name": "@rockhopper/mcp-server",
  "version": "0.1.0",
  "description": "Rockhopper MCP server — expose file metadata, versions, reviews, and comments to AI tools",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "rockhopper-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "keywords": [
    "mcp",
    "rockhopper",
    "excel",
    "file-management",
    "ai-tools"
  ],
  "license": "UNLICENSED",
  "private": true
}
